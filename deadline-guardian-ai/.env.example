# Copy this file to ".env" (or ".env.local") and fill in your own values.
# SECURITY_NOTE: Never commit a real key. ".env" / ".env.local" are gitignored.
# The app runs fully in an offline "Mock AI Mode" when GEMINI_API_KEY is blank.
#
# SECURE ARCHITECTURE:  React Frontend -> Backend API Route -> Gemini API
#   The Gemini API key is used ONLY by the backend server (server/index.js).
#   It is read from process.env.GEMINI_API_KEY and is NEVER exposed to the
#   browser. The frontend talks only to our own /api/ai/* endpoints.
#
# Get a free Gemini API key from Google AI Studio:
#   https://aistudio.google.com/app/apikey

# --- Backend (server-only) ----------------------------------------------------
# Your Google AI Studio API key. PLACEHOLDER ONLY - never commit a real key.
GEMINI_API_KEY=your_google_ai_studio_key_here

# Optional: which Gemini model to use. Defaults to gemini-2.5-flash-lite when unset.
# (The retired gemini-1.5-flash returns 404 on the public v1beta endpoint.)
GEMINI_MODEL=gemini-2.5-flash-lite

# Port the backend listens on. Cloud Run / AI Studio inject their own PORT and
# 8080 is the production default. For local dev you may set PORT=3001 to match
# the Vite proxy (or leave 8080 - the dev proxy follows whatever you set here).
PORT=8080

# Optional: in production, set this to your deployed frontend origin so CORS
# allows it (e.g. https://your-app.example.com). Not needed for local dev.
# CLIENT_ORIGIN=https://your-deployed-frontend.example.com
